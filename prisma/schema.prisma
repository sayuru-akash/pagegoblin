generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ReportVisibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

enum ReportSource {
  WEB_URL
  EXTENSION
  MANUAL_SIGNALS
}

enum RoastMode {
  DETERMINISTIC
  AI_ASSISTED
  HYBRID
}

enum ApiProviderType {
  OPENAI_COMPATIBLE
  OPENAI
  OTHER
}

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           UserRole  @default(USER)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  reports   Report[]
  auditLogs AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Report {
  id              String           @id @default(cuid())
  slug            String           @unique
  userId          String?
  source          ReportSource
  roastMode       RoastMode        @default(DETERMINISTIC)
  visibility      ReportVisibility @default(UNLISTED)
  url             String
  normalizedUrl   String
  domain          String
  title           String?
  metaDescription String?
  signals         Json
  metrics         Json
  score           Int
  biggestCrime    String
  verdict         String
  summaryMarkdown String           @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user   User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  shares ShareLink[]

  @@index([userId])
  @@index([domain])
  @@index([score])
  @@index([createdAt])
  @@index([visibility])
  @@map("reports")
}

model ShareLink {
  id         String           @id @default(cuid())
  reportId   String
  token      String           @unique
  visibility ReportVisibility @default(UNLISTED)
  expiresAt  DateTime?
  createdAt  DateTime         @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([createdAt])
  @@map("share_links")
}

model ApiConfig {
  id             String         @id @default(cuid())
  name           String         @unique
  providerType   ApiProviderType @default(OPENAI_COMPATIBLE)
  baseUrl        String?
  encryptedApiKey String        @db.Text
  model          String
  enabled        Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  lastTestedAt   DateTime?
  lastTestStatus String?

  @@map("api_configs")
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
